# DeepSeek API Key(情感分析用,免费注册:https://platform.deepseek.com/)
# 留空 = 自动降级到规则模式
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 调度频率(秒)
CRAWL_INTERVAL=1800
WEIBO_INTERVAL=30
ZHIHU_INTERVAL=60
BILIBILI_INTERVAL=90
BAIDU_INTERVAL=60

# 抓取上限
MAX_POSTS_PER_KEYWORD=50
MAX_BILIBILI_COMMENTS=500

# 代理(可选,如果你有)
# HTTP_PROXY=http://127.0.0.1:7890

# 平台开关
ENABLE_WEIBO=true
ENABLE_ZHIHU=true
ENABLE_BILIBILI=true
ENABLE_BAIDU_XHS=true
ENABLE_BAIDU_DOUYIN=true

# 服务
HOST=127.0.0.1
PORT=8000
